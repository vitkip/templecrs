APP_NAME="Buddhist Organization Management System"

# ════════════════════════════════════════════
# LOCAL  → APP_ENV=local  | APP_DEBUG=true
# SERVER → APP_ENV=production | APP_DEBUG=false
# ════════════════════════════════════════════
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# LOCAL:  http://127.0.0.1:8000
# SERVER: https://www.templecrs.com
APP_URL=http://127.0.0.1:8000

APP_LOCALE=lo
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ════════════════════════════════════════════
# LOGGING
# LOCAL: debug | SERVER: error
# ════════════════════════════════════════════
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ════════════════════════════════════════════
# DATABASE
# LOCAL:  DB_HOST=127.0.0.1 | DB_DATABASE=templecrs | DB_USERNAME=root | DB_PASSWORD=
# SERVER: DB_HOST=localhost  | DB_DATABASE=<db_name>  | DB_USERNAME=<db_user> | DB_PASSWORD=<db_pass>
# ════════════════════════════════════════════
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=templecrs
DB_USERNAME=root
DB_PASSWORD=

# ════════════════════════════════════════════
# SESSION & CACHE
# LOCAL:  SESSION_DRIVER=database | CACHE_STORE=database
# SERVER: SESSION_DRIVER=file     | CACHE_STORE=file
# ════════════════════════════════════════════
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database

# ════════════════════════════════════════════
# FILESYSTEM & QUEUE
# LOCAL:  FILESYSTEM_DISK=local    | QUEUE_CONNECTION=database
# SERVER: FILESYSTEM_DISK=public   | QUEUE_CONNECTION=sync
# ════════════════════════════════════════════
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ════════════════════════════════════════════
# MAIL
# ════════════════════════════════════════════
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@templecrs.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
